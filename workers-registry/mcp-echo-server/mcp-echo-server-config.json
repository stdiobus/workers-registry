{
  "pools": [
    {
      "id": "mcp-echo-server",
      "command": "/usr/bin/env",
      "args": [
        "node",
        "./examples/mcp-echo-server/dist/mcp-echo-server.js"
      ],
      "instances": 1
    }
  ],
  "limits": {
    "max_input_buffer": 1048576,
    "max_output_queue": 4194304,
    "max_restarts": 5,
    "restart_window_sec": 60,
    "drain_timeout_sec": 30,
    "backpressure_timeout_sec": 60
  }
}