{
  "name": "@stdiobus/registry-launcher",
  "version": "1.0.0",
  "description": "Registry Launcher - routes messages to ACP Registry agents with OAuth 2.1 authentication",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/prepare-executables.js",
    "build:ts": "tsc",
    "start": "node dist/index.js",
