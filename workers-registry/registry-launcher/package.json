    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist",
    "prepare-executables": "node scripts/prepare-executables.js"
  },
  "keywords": [
    "acp",
    "registry",
    "launcher",
    "oauth",
    "agent",
    "protocol"
