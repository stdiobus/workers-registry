{
  "pools": [
    {
      "id": "openai-agent",
      "command": "node",
      "args": [
        "./workers-registry/openai-agent/dist/index.js"
      ],
      "instances": 1
    }
  ],
  "limits": {
    "max_input_buffer": 1048576,
    "max_output_queue": 4194304,
    "max_restarts": 3,
    "restart_window_sec": 60
  }
}