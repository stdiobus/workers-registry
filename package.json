  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "fast-check": "^3.22.0",
    "jest": "^29.7.0"
  }
